# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chaoqun_sign?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Session
SESSION_SECRET="replace-with-random-32-char-string"

# Signing token
SIGN_TOKEN_SECRET="replace-with-random-32-char-string"
SIGN_TOKEN_EXPIRY_HOURS="72"

# Aliyun SMS
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME="超群粮油"
ALIYUN_SMS_TEMPLATE_CODE=""
ALIYUN_SMS_SIGN_LINK_TEMPLATE_CODE=""

# Aliyun OSS
ALIYUN_OSS_ACCESS_KEY_ID=""
ALIYUN_OSS_ACCESS_KEY_SECRET=""
ALIYUN_OSS_BUCKET="chaoqun-sign"
ALIYUN_OSS_REGION="oss-cn-xian"
ALIYUN_OSS_ENDPOINT="https://oss-cn-xian.aliyuncs.com"

# 金蝶云星辰 Open API (JDY v2)
# 开放平台凭据（从 open.jdy.com 获取）
KINGDEE_CLIENT_ID=""
KINGDEE_CLIENT_SECRET=""
# 应用凭据（授权安装后获得，appSecret 24h 刷新）
KINGDEE_APP_KEY=""
KINGDEE_APP_SECRET=""
# 网关路由地址（IDC 域名，如 https://tf.jdy.com）
KINGDEE_GW_ROUTER_ADDR=""
# 可选：覆盖默认 base URL
# KINGDEE_BASE_URL="https://api.kingdee.com/jdy/v2"
# KINGDEE_AUTH_URL="https://api.kingdee.com/jdyconnector/app_management/kingdee_auth_token"

# 飞书 Lark (webhook callback)
LARK_WEBHOOK_URL=""
LARK_WEBHOOK_SECRET=""

# 莱运 Webhook (inbound from 莱运 agent)
LAIYUN_WEBHOOK_SECRET="replace-with-shared-secret"

# Printer
DEFAULT_PRINTER_NAME="default"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="超群签收"
